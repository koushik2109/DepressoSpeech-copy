# ── MindScope Backend Configuration ──
# Copy this to .env and fill in values

# ── Application ──
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
API_V1_PREFIX=/api/v1

# ── Database (SQLite for dev, PostgreSQL for production) ──
DATABASE_URL=sqlite+aiosqlite:///./mindscope.db
DATABASE_ECHO=false

# ── JWT Auth ──
JWT_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ──
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://127.0.0.1:5173"]

# ── File Storage ──
STORAGE_LOCAL_PATH=./storage/audio
AUDIO_MAX_FILE_SIZE_MB=100
AUDIO_ALLOWED_EXTENSIONS=.wav,.mp3,.flac,.ogg,.m4a,.webm

# ── ML Model ──
ML_MODEL_PATH=../Model/checkpoints/best_model.pt
ML_CONFIG_PATH=../Model/configs/inference_config.yaml
ML_DEVICE=auto

# ── Admin Defaults ──
ADMIN_DEFAULT_EMAIL=admin@mindscope.ai
ADMIN_DEFAULT_PASSWORD=Admin@2026!

# ── SMTP (for OTP verification emails) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
OTP_EXPIRE_MINUTES=10

# ── Google OAuth ──
# Get your client ID from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
